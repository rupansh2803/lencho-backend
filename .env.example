# ════════════════════════════════════════════════════════════════
# LENCHO BACKEND CONFIGURATION
# Copy this to .env and fill in your values
# NEVER commit .env to Git (it's in .gitignore)
# ════════════════════════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────────────────────────
# MongoDB Connection String
# 🔴 FOR PRODUCTION (MongoDB Atlas):
# 1. Go: https://account.mongodb.com
# 2. Create cluster → Get connection string
# 3. Replace <password> and <dbname>
# Example: mongodb+srv://lencho_admin:Strong%40Password123@lencho-cluster.xxxxx.mongodb.net/lencho-db?retryWrites=true&w=majority
# IMPORTANT: If your password has @, #, %, /, ?, spaces, etc. URL-encode it before saving.
MONGODB_URI=mongodb+srv://lencho_admin:PASSWORD_HERE@lencho-cluster.xxxxx.mongodb.net/lencho-db?retryWrites=true&w=majority
MONGODB_DB_NAME=lencho
# Optional aliases (backend accepts these too):
# MONGO_URI=
# DATABASE_URL=

# MongoDB is required. If it is missing/unreachable, the server stops instead of using temporary JSON storage.
REQUIRE_MONGODB=true

# ── SESSION & SECURITY ────────────────────────────────────────────
# Generate strong random keys:
# TERMINAL: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-random-key-and-paste-here
JWT_SECRET=generate-another-random-key-and-paste-here

# ── ENVIRONMENT ───────────────────────────────────────────────────
# 🔴 For Render: NODE_ENV=production
NODE_ENV=development
# development or production
FRONTEND_URL=https://lencho.in
SITE_URL=https://lencho.in

# Server port (Render overrides this automatically)
PORT=30054

# ── CORS ALLOWED ORIGINS ──────────────────────────────────────────
# For production, set to your actual domain
CORS_ORIGIN=http://localhost:3000,http://localhost:30054,https://lencho.in,https://www.lencho.in,https://api.lencho.in

# ── SMS & OTP ──────────────────────────────────────────────────────
# Fast2SMS API key (optional, for SMS OTP verification)
# Get free key from: https://www.fast2sms.com
# Leave empty to disable SMS (OTPs will show in console)
FAST2SMS_KEY=

# ── EMAIL CONFIGURATION (Gmail SMTP) ───────────────────────────────
# 🔴 CRITICAL FOR OTP EMAILS - Follow these steps:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer"
# 3. Copy the 16-character App Password (without spaces)
# 4. Paste it below in SMTP_PASS and EMAIL_PASS fields
# 
# ⚠️ COMMON MISTAKES:
# - Using regular Gmail password instead of App Password
# - Forgetting to enable 2-Factor Authentication first
# - Including spaces in the app password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=lencho.official001@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_USER=lencho.official001@gmail.com
EMAIL_PASS=your-16-char-app-password
INQUIRY_REPLY_EMAIL=lencho.official001@gmail.com
INQUIRY_REPLY_PASS=your-16-char-app-password

# ── ADMIN CREDENTIALS (Change before production!) ─────────────────
CREATE_INITIAL_ADMIN=false
ADMIN_NAME=Lencho Owner
ADMIN_EMAIL=lencho.official001@gmail.com
ADMIN_ALERT_EMAIL=lencho.official001@gmail.com
ADMIN_ALERT_EMAILS=lencho.official001@gmail.com,rupanshsaini17@gmail.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_PHONE=
ADMIN_SECONDARY_EMAILS=rupanshsaini17@gmail.com

# Optional employee admin accounts. Keep real values in Render/local .env only.
# Option 1: matching comma lists
ADMIN_EMPLOYEE_EMAILS=employee1@example.com,employee2@example.com
ADMIN_EMPLOYEE_PASSWORDS=employee1-strong-password,employee2-strong-password
ADMIN_EMPLOYEE_NAMES=Employee One,Employee Two
# Option 2: one value per employee, separated by semicolon. Format: email|password|name
# ADMIN_EMPLOYEES=employee1@example.com|strong-password|Employee One;employee2@example.com|strong-password|Employee Two
# Leave false unless you intentionally want env passwords to overwrite existing admin passwords on boot.
SYNC_ADMIN_PASSWORDS=false

# ── BUSINESS SETTINGS ─────────────────────────────────────────────
# WhatsApp Business number (for chat widget)
WHATSAPP_NUMBER=919999999999
STORE_EMAIL=lencho.official001@gmail.com
STORE_PHONE=+91-7404217625

# ── PAYMENT GATEWAYS (Optional) ───────────────────────────────────
# Razorpay (for card/UPI payments)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# ── ORDER / INQUIRY EMAILS ────────────────────────────────────────
# The backend reuses the Gmail SMTP settings above for OTP, inquiry
# auto-replies, admin inquiry notifications, and order/customer emails.
# Keep SMTP_USER/EMAIL_USER/INQUIRY_REPLY_EMAIL as lencho.official001@gmail.com
# and put the Gmail App Password only in Render/local .env, never in GitHub.

# ════════════════════════════════════════════════════════════════
# 🚀 PRODUCTION DEPLOYMENT CHECKLIST
# ════════════════════════════════════════════════════════════════
# 
# Before pushing to Render:
# [ ] MONGODB_URI updated with real MongoDB Atlas connection string
# [ ] JWT_SECRET generated with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# [ ] SESSION_SECRET generated with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# [ ] NODE_ENV set to 'production'
# [ ] ADMIN_PASSWORD changed to something secure
# [ ] CORS_ORIGIN includes your domain (https://lencho.in)
# [ ] All secrets added to Render Environment Variables (NOT hardcoded)
# [ ] Database backup created before first deployment
#
# ════════════════════════════════════════════════════════════════

# ── SHIPMENT & LOGISTICS (Optional) ───────────────────────────
# Shiprocket API (for shipping integration)
SHIPROCKET_API_TOKEN=
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ── GOOGLE APIs (Optional) ────────────────────────────────────
# For analytics and optimization
GOOGLE_ANALYTICS_ID=
GOOGLE_SEARCH_CONSOLE_ID=

# Lencho admin AI assistant. Keep the real key only in Render/local .env.
LENCHO_AI_ENABLED=true
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_REALTIME_MODEL=gpt-realtime

# GA4 real visitor totals in admin dashboard.
# Never commit the real JSON key. Put the base64 JSON in Render Environment.
GA4_PROPERTY_ID=539346966
GA4_SERVICE_ACCOUNT_JSON_BASE64=
# Alternative to JSON base64:
# GA4_CLIENT_EMAIL=firebase-adminsdk-fbsvc@lencho-b556e.iam.gserviceaccount.com
# GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── FIREBASE AUTH (Google Sign-In) ────────────────────────────
# Firebase web config for frontend Google login flow.
# These are safe for client-side usage, but keep project ownership secure.
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# ─ BUSINESS DETAILS ───────────────────────────────────────────
STORE_NAME=Lencho
STORE_EMAIL=lencho.official001@gmail.com
STORE_PHONE=+91 7404217625
GSTIN=27XXXXX1234X1ZX

# ─ API KEYS & TOKENS ──────────────────────────────────────────
# ─ CLOUDINARY (for media uploads) ─────────────────────────────────
# Create a Cloudinary account and fill these values to enable cloud uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─ MISC SETTINGS ──────────────────────────────────────────────
# Site URL for links in emails
SITE_URL=https://lencho.in
API_URL=https://lencho-backend.onrender.com
